/* ─────────────────────────────────────────────
   GLOBAL STYLES
──────────────────────────────────────────── */

body {
  font-family: Arial, sans-serif;
  font-size: 18px;
  margin: 0;
  padding: 0;
}

/* ─────────────────────────────────────────────
   HEADER
──────────────────────────────────────────── */

header {
  background-color: #4a90e2;
  padding: 20px;
}

/* ─────────────────────────────────────────────
   NAVIGATION
──────────────────────────────────────────── */

nav {
  background-color: #333;
  padding: 10px;
}

nav ul {
  margin: 0;
  padding: 0;
}

li {
  display: inline-block;
  width: 120px;
  list-style: none;
  text-align: center;
}

/* ─────────────────────────────────────────────
   MAIN CONTENT
──────────────────────────────────────────── */

main {
  background-color: #f4f4f4;
  font-size: 20px;
  padding: 15px;
}

/* ─────────────────────────────────────────────
   FOOTER
──────────────────────────────────────────── */

footer {
  background-color: #222;
  color: white;
  padding: 15px;
  text-align: center;
}

/* ─────────────────────────────────────────────
   TEXT ELEMENTS
──────────────────────────────────────────── */

h1 {
  text-align: center;
  font-family: "Georgia", serif;
  color: darkblue;
}

p {
  line-height: 1.6;
}
